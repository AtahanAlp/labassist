# ============================================================================
# LabAssist environment template — copy to `.env` and adjust as needed.
# `.env` is git-ignored; never commit real secrets.
# ============================================================================

# ---- PostgreSQL ----
POSTGRES_DB=labassist
POSTGRES_USER=labassist
POSTGRES_PASSWORD=labassist_pw
POSTGRES_PORT=5432

# ---- Backend (Spring Boot) ----
BACKEND_PORT=8080
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/labassist
SPRING_DATASOURCE_USERNAME=labassist
SPRING_DATASOURCE_PASSWORD=labassist_pw

# JWT signing secret — MUST be a long, random, Base64-ish string (>= 32 bytes).
# Generate one with:  openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-bytes-long!!
JWT_EXPIRATION_MINUTES=60

# AES-256-GCM key for patient PII field encryption.
# Preferred: Base64 of exactly 32 random bytes  ->  openssl rand -base64 32
# Any other non-empty string is also accepted and hashed (SHA-256) into a 256-bit key.
PII_ENCRYPTION_KEY=DJOxEDA9JiEEcrVM2jQkE5625vpBt3/9dwBQ0kWQ9AM=

# Seed doctor account (created by Flyway/runner on first boot)
SEED_DOCTOR_USERNAME=doctor
SEED_DOCTOR_PASSWORD=Doctor123!

# ---- Mock lab device ----
MOCK_DEVICE_PORT=9090
# Base URL the backend uses to poll the device (service name inside compose).
LAB_DEVICE_BASE_URL=http://mock-lab-device:9090
# Polling cadence in milliseconds.
INGESTION_POLL_INTERVAL_MS=5000

# ---- Ollama (LLM) ----
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_TIMEOUT_SECONDS=120

# ---- Frontend ----
FRONTEND_PORT=5173
# Base URL the browser uses to reach the backend API.
VITE_API_BASE_URL=http://localhost:8080
